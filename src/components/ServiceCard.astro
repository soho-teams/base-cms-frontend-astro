---
import type { ServiceList } from "~/lib/types";
import { assetUrl } from "~/lib/api";
interface Props { service: ServiceList; }
const { service } = Astro.props;
const iconUrl = assetUrl(service.icon, "small");
---
<a href={`/services/${service.slug}`}
   class="group block bg-white rounded-2xl border border-slate-200 p-6 hover:border-brand-300 hover:shadow-lg hover:shadow-brand-100/40 transition">
  {iconUrl ? (
    <div class="w-12 h-12 mb-4 rounded-xl bg-brand-50 flex items-center justify-center overflow-hidden">
      <img src={iconUrl} alt="" class="w-8 h-8 object-contain" />
    </div>
  ) : (
    <div class="w-12 h-12 mb-4 rounded-xl bg-brand-50 flex items-center justify-center text-brand-600 font-bold text-xl">
      {service.name.charAt(0)}
    </div>
  )}
  <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-brand-600 transition">
    {service.name}
  </h3>
  {service.short_description && (
    <p class="text-sm text-slate-600 leading-relaxed">{service.short_description}</p>
  )}
  {service.price_range && (
    <p class="text-xs font-semibold text-brand-600 mt-4">{service.price_range}</p>
  )}
</a>
