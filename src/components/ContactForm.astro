---
// ContactForm — POSTs to /api/v1/forms/submit/
// Server-rendered shell + Alpine.js handles submit/loading/result states.
const apiUrl = import.meta.env.PUBLIC_CMS_API_URL ?? "http://localhost:8000";
---

<form
  x-data={`{
    loading: false,
    success: false,
    error: '',
    async submit(e) {
      this.loading = true;
      this.error = '';
      const form = e.target;
      const data = {
        form_type: 'contact',
        name: form.name.value,
        email: form.email.value,
        phone: form.phone.value,
        subject: form.subject.value,
        message: form.message.value,
        website: form.website.value,
      };
      try {
        const res = await fetch('${apiUrl}/api/v1/forms/submit/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) {
          let detail = 'Failed to send. Please try again.';
          try { const body = await res.json(); detail = body.detail || JSON.stringify(body); } catch (e) {}
          throw new Error(detail);
        }
        this.success = true;
        form.reset();
      } catch (e) {
        this.error = e.message;
      } finally {
        this.loading = false;
      }
    }
  }`}
  @submit.prevent="submit($event)"
  class="space-y-4"
>
  <!-- Success state -->
  <div x-show="success" x-cloak class="bg-green-50 border border-green-200 rounded-lg p-4 text-sm text-green-800 flex items-start gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 flex-shrink-0 mt-0.5">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
    </svg>
    <div>
      <p class="font-semibold">Thanks!</p>
      <p>Your message has been sent. We'll get back to you soon.</p>
    </div>
  </div>

  <!-- Error state -->
  <div x-show="error" x-cloak class="bg-red-50 border border-red-200 rounded-lg p-4 text-sm text-red-800 flex items-start gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 flex-shrink-0 mt-0.5">
      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
    </svg>
    <p x-text="error"></p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-xs font-semibold text-slate-600 mb-1.5" for="cf-name">Name</label>
      <input id="cf-name" name="name" type="text" required
             class="w-full px-3.5 py-2.5 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition" />
    </div>
    <div>
      <label class="block text-xs font-semibold text-slate-600 mb-1.5" for="cf-email">Email</label>
      <input id="cf-email" name="email" type="email" required
             class="w-full px-3.5 py-2.5 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition" />
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <label class="block text-xs font-semibold text-slate-600 mb-1.5" for="cf-phone">Phone <span class="font-normal text-slate-400">(optional)</span></label>
      <input id="cf-phone" name="phone" type="tel"
             class="w-full px-3.5 py-2.5 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition" />
    </div>
    <div>
      <label class="block text-xs font-semibold text-slate-600 mb-1.5" for="cf-subject">Subject <span class="font-normal text-slate-400">(optional)</span></label>
      <input id="cf-subject" name="subject" type="text"
             class="w-full px-3.5 py-2.5 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition" />
    </div>
  </div>

  <div>
    <label class="block text-xs font-semibold text-slate-600 mb-1.5" for="cf-message">Message</label>
    <textarea id="cf-message" name="message" rows="5" required
              class="w-full px-3.5 py-2.5 text-sm border border-slate-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-brand-300 focus:border-brand-400 transition resize-y"></textarea>
  </div>

  <!-- Honeypot — bots fill this; humans don't see it. Don't use display:none (some bots avoid that). -->
  <div style="position:absolute;left:-9999px;height:0;overflow:hidden" aria-hidden="true">
    <label for="cf-website">Website</label>
    <input id="cf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
  </div>

  <button type="submit" :disabled="loading"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-slate-900 text-white text-sm font-semibold rounded-lg hover:bg-slate-700 transition disabled:opacity-60 disabled:cursor-not-allowed">
    <svg x-show="loading" x-cloak xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 animate-spin">
      <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 18a8 8 0 110-16 8 8 0 010 16z" opacity="0.25"/>
      <path d="M12 2a10 10 0 0110 10h-2a8 8 0 00-8-8V2z"/>
    </svg>
    <span x-text="loading ? 'Sending…' : 'Send message'"></span>
  </button>
</form>

<style>
  [x-cloak] { display: none !important; }
</style>
