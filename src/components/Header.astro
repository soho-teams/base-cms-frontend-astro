---
import type { MenuItem, SiteSettings } from "~/lib/types";
import { assetUrl } from "~/lib/api";

interface Props {
  settings: SiteSettings;
  menuItems: MenuItem[];
}

const { settings, menuItems } = Astro.props;
const logoUrl = assetUrl(settings.logo, "medium");
---
<header class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2.5 font-bold text-lg text-slate-900">
        {logoUrl ? (
          <img src={logoUrl} alt={settings.site_name} class="h-8 w-auto" />
        ) : (
          <span class="text-brand-600">●</span>
        )}
        <span>{settings.site_name}</span>
      </a>

      <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
        {menuItems.length > 0 ? (
          menuItems.map((item) => (
            <li><a href={item.url} class="hover:text-slate-900 transition">{item.label}</a></li>
          ))
        ) : (
          <>
            <li><a href="/services" class="hover:text-slate-900 transition">Services</a></li>
            <li><a href="/projects" class="hover:text-slate-900 transition">Projects</a></li>
            <li><a href="/blog" class="hover:text-slate-900 transition">Blog</a></li>
            <li><a href="/about" class="hover:text-slate-900 transition">About</a></li>
          </>
        )}
      </ul>

      <a href="/contact"
         class="hidden md:inline-flex items-center gap-2 px-4 py-2 bg-brand-600 text-white text-sm font-semibold rounded-lg hover:bg-brand-700 transition">
        Contact
      </a>
    </nav>
  </div>
</header>
