---
import type { PostList } from "~/lib/types";
interface Props { post: PostList; }
const { post } = Astro.props;
const date = post.published_at ? new Date(post.published_at).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }) : "";
---
<a href={`/blog/${post.slug}`} class="group block">
  <p class="text-xs text-slate-500 mb-2">{date}</p>
  <h3 class="text-lg font-bold text-slate-900 group-hover:text-brand-600 transition mb-2">{post.title}</h3>
  {post.excerpt && <p class="text-sm text-slate-600 leading-relaxed line-clamp-3">{post.excerpt}</p>}
  <p class="text-sm font-semibold text-brand-600 mt-3 group-hover:gap-2 transition-all inline-flex items-center gap-1">
    Read more <span aria-hidden>→</span>
  </p>
</a>
